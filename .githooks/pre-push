#!/bin/sh
# Pre-push gate — the last line before code becomes PUBLIC (github.com/syskin/mathieu-cadu).
# Wired via `git config core.hooksPath .githooks` (prepare script).
# Heavier than pre-commit on purpose: a public push is rare and high-stakes.
set -e

echo "› pre-push: full verify before public push…"

# 1. Quality gate (types + lint + content provenance + tests).
pnpm -s check

# 2. Production build must succeed — a public site that doesn't build is unacceptable.
echo "› pre-push: production build…"
pnpm -s build >/dev/null

# 3. Secret scan — public repo, nothing sensitive may leave the machine.
if git grep -I -l -e 'BEGIN OPENSSH PRIVATE KEY' -e 'BEGIN RSA PRIVATE KEY' -e 'BEGIN PRIVATE KEY' -- . >/dev/null 2>&1; then
  echo "✗ pre-push: private key material found in tracked files. Aborting." >&2
  exit 1
fi
leak=$(git ls-files | grep -E '(^|/)\.env($|\.)' | grep -vE '\.(example|sample|template)$' || true)
if [ -n "$leak" ]; then
  echo "✗ pre-push: tracked env file(s) would be published:" >&2
  echo "$leak" >&2
  exit 1
fi

echo "✓ pre-push: green, safe to publish."
