#!/bin/sh
# Pre-push gate — the last line before code becomes PUBLIC (github.com/syskin/mathieu-cadu).
# Wired via `git config core.hooksPath .githooks` (prepare script).
# Heavier than pre-commit on purpose: a public push is rare and high-stakes.
set -e

echo "› pre-push: full verify before public push…"

# 1. Quality gate — types + lint + content provenance + security (PII/secrets/.env) + tests.
pnpm -s check

# 2. Production build must succeed — a public site that doesn't build is unacceptable.
echo "› pre-push: production build…"
pnpm -s build >/dev/null

# 3. Supply chain — block high/critical dependency advisories (network-bound, push only).
echo "› pre-push: supply-chain audit…"
pnpm -s harness:supply

echo "✓ pre-push: green, safe to publish."
